# ---------------------------------------------------------------------------
# Pulse — environment
#
# The two required vars are the first two. Everything below them is optional
# and only unlocks a specific feature (Stripe, cron, alerts).
# ---------------------------------------------------------------------------

# --- Required (the "two env vars" setup path) ------------------------------

# Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/publishable key. Safe to expose: RLS is what protects the data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=


# --- Strongly recommended --------------------------------------------------

# Supabase service role key. SERVER ONLY — never prefix with NEXT_PUBLIC_.
# The ingest collector uses it to write events past RLS. Without it, ingestion
# is disabled and Pulse runs read-only.
SUPABASE_SERVICE_ROLE_KEY=

# Public origin of this deployment, used to build the copy-paste snippet.
# e.g. https://pulse.devmello.xyz
NEXT_PUBLIC_SITE_URL=https://pulse.devmello.xyz

# Locks the owner dashboard to a single account. Comma-separated emails.
# Leave blank to let the first user who signs up claim ownership.
PULSE_OWNER_EMAILS=


# --- Optional: Stripe revenue ----------------------------------------------

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# --- Optional: cron ---------------------------------------------------------

# Shared secret for /api/cron/* routes when driving rollups from Vercel Cron.
# Not needed if you use Supabase pg_cron (the default in the migrations).
CRON_SECRET=


# --- Optional: public site visibility (defaults to enabled) -----------------

# Set to false to hide the marketing landing page at /.
NEXT_PUBLIC_PULSE_SHOW_LANDING=true

# Set to false to hide the live demo / public stats page at /stats.
NEXT_PUBLIC_PULSE_SHOW_LIVE=true


# --- Optional: display currency --------------------------------------------

# ISO 4217 code that mixed-currency totals are normalized into. Default USD.
PULSE_DISPLAY_CURRENCY=USD

# Static FX rates as JSON, relative to the display currency above.
# e.g. {"EUR":1.09,"GBP":1.27} means 1 EUR = 1.09 USD.
# Rates are only used for combined display totals; native currency is always
# stored untouched.
PULSE_FX_RATES=
